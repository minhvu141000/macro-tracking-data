# Copy this file to .env and fill in your API keys

# FRED (required): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Census Bureau (optional — enables trade detail: breakdown by country + end-use on Trade Balance days)
# Free, instant registration: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=
